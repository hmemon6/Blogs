{
    "version": 2,
    "builds": [
        {
            "src": "blog_project/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "runtime": "python3.11.9",
                "maxLambdaSize": "50mb",
                "buildCommand": "bash setip.sh"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "blog_project/wsgi.py"
        }
    ]
}